import os
from langchain_community.document_loaders import TextLoader, PyPDFLoader, Docx2txtLoader
from langchain_text_splitters import CharacterTextSplitter
from langchain_community.embeddings import HuggingFaceEmbeddings
from langchain_community.vectorstores import FAISS

DOCUMENTS_FOLDER = "./Baza_Znaniy"
PROGRAM_FOLDER = '.'

def load_document(file_path):
    if file_path.endswith('.pdf'):
        loader = PyPDFLoader(file_path)
        print(f"Обрабатываем PDF: {file_path}")
        return loader.load()
    elif file_path.endswith('.docx'):
        loader = Docx2txtLoader(file_path)
        print(f"Обрабатываем DOCX: {file_path}")
        return loader.load()
    else:
        encodings = ['utf-8', 'cp1251', 'koi8-r', 'latin-1']
        for enc in encodings:
            try:
                loader = TextLoader(file_path, encoding=enc)
                print(f"Обрабатываем текст ({enc}): {file_path}")
                return loader.load()
            except UnicodeDecodeError:
                continue
        raise RuntimeError(f"Не удалось прочитать файл {file_path} ни в одной кодировке")

all_documents = []
for filename in os.listdir(DOCUMENTS_FOLDER):
    file_path = os.path.join(DOCUMENTS_FOLDER, filename)
    if os.path.isfile(file_path):
        try:
            docs = load_document(file_path)
            all_documents.extend(docs)
            print(f"Загружено {len(docs)} фрагментов")
        except Exception as e:
            print(f"Ошибка при загрузке {filename}: {e}")

print(f"\nВсего загружено фрагментов: {len(all_documents)}")

text_splitter = CharacterTextSplitter(chunk_size=500, chunk_overlap=50)
chunks = text_splitter.split_documents(all_documents)
print(f"Разбито на {len(chunks)} фрагментов")

embeddings = HuggingFaceEmbeddings(
    model_name="intfloat/multilingual-e5-small",
    model_kwargs={"token": "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"}
)

print("Строим векторную базу")
vector_db = FAISS.from_documents(chunks, embeddings)

vector_db.save_local("./faiss_index")
print(f"\nБаза знаний сохранена в папку './faiss_index'")
print(f"Всего {len(chunks)} фрагментов")

#vector_db = FAISS.load_local("./faiss_index", embeddings, allow_dangerous_deserialization=True)

all_pairs = []

def ask_assistant(question):
    docs_with_scores = vector_db.similarity_search_with_score(question, k=10)

    RELEVANCE_THRESHOLD = .5
    relevant_docs = [doc for doc, score in docs_with_scores if score < RELEVANCE_THRESHOLD]

    if not relevant_docs:
        return "В загруженных документах нет информации на этот вопрос. Попробуйте перефразировать."

    context_parts = []
    for i, doc in enumerate(relevant_docs):
        content = doc.page_content
        context_parts.append(f"[Фрагмент {i+1}]:\n{content}")

    context = "\n\n".join(context_parts)

    prompt = f"""Ты — ассистент ВИШа, института в РУТ (МИИТ).

### ТВОЯ ЗАДАЧА:
Найди в контексте информацию, которая относится к вопросу пользователя.
Объедини информацию из разных фрагментов в один связный ответ.

### ВАЖНЫЕ ПРАВИЛА:
1. Используй ТОЛЬКО информацию из контекста.
2. НЕ добавляй информацию из своих знаний.
3. Если в контексте нет ответа на вопрос — напиши:
   "В загруженных документах нет информации на этот вопрос. Попробуйте перефразировать."
4. НЕ рисуй таблицы. ЗАПРЕЩЕНЫ символы | и ---.
5. Используй ТОЛЬКО обычный текст.

### КОНТЕКСТ:
{context}

### ВОПРОС ПОЛЬЗОВАТЕЛЯ:
{question}

### ТВОЙ ОТВЕТ (только по контексту, только текстом):"""

    response = giga.chat(prompt)
    return response.choices[0].message.content

def save_pairs(pairs):
    with open('qa_pairs.txt', 'w', encoding='utf-8') as f:
        for question, answer in pairs:
            f.write("=" * 30 + "+++" + "=" * 30 + "\n")
            f.write(f"Вопрос: {question}\n")
            f.write(f"Ответ: {answer}\n")
            f.write("=" * 30 + "+++" + "=" * 30 + "\n")
    
    print(f"Сохранено {len(pairs)} пар вопрос-ответ в файл qa_pairs.txt")

running = True

while running:
  question = input("Пользователь: ")

  if question == "_save":
    save_pairs(all_pairs)
    print("Сохраняем q/a")
    
  elif question == "_cleartemp":
    all_pairs = []
    print("Пары q/a подчищены.")
    
  elif question == "_clearqa":
    for filename in os.listdir(PROGRAM_FOLDER):
      if filename == 'qa_pairs.txt':
        os.remove(filename)
    
  elif question == "_print":
    print(all_pairs)
    
  elif question == "_exit":
    choose = input("Сохранить q/a? (Y/N)")
    if choose == 'Y':      
      save_pairs(all_pairs)
      all_pairs = []
      break
      
    if choose == 'N':
      all_pairs = []
      break

  else:

    answer = ask_assistant(question)
    print("Пользователь: " + question)
    print("WishAI: " + answer)

    pair = (question, answer)
    all_pairs += [pair]
